,"errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"71","usedDeprecatedRules":"36"},"C:\\dev\\podjs\\src\\index.js",[],["72","73","74","75","76"],"C:\\dev\\podjs\\src\\App.js",[],["77","78","79","80","81"],"C:\\dev\\podjs\\src\\reportWebVitals.js",[],["82","83","84","85","86"],"C:\\dev\\podjs\\src\\components\\DarkThemeProvider\\DarkThemeProvider.js",[],"C:\\dev\\podjs\\src\\components\\Navigator\\Navigator.js",[],"C:\\dev\\podjs\\src\\screens\\Dashboard\\Dashboard.js",[],"C:\\dev\\podjs\\src\\components\\PodcastCard\\PodcastCard.js",[],"C:\\dev\\podjs\\src\\hooks\\useContextFactory.js",[],"C:\\dev\\podjs\\src\\contexts\\Podcasts\\actions.js",["87","88","89","90","91","92","93","94","95","96"],"C:\\dev\\podjs\\src\\contexts\\Podcasts\\types.js",[],"C:\\dev\\podjs\\src\\contexts\\Podcasts\\context.js",[],"C:\\dev\\podjs\\src\\contexts\\Podcasts\\provider.js",["97","98"],"/* eslint-disable react/prop-types */\nimport React, { useCallback, useMemo, useState } from 'react';\nimport {\n  PodcastsContext,\n  PodcastsActionsContext,\n  PodcastsInitialState,\n} from './context';\nimport {\n  GET_TOP_PODCASTS,\n  GET_PODCAST_DETAIL,\n  RESET_PODCASTS,\n  PLAY_PODCAST_ITEM,\n} from './types';\nimport dispatch from './actions';\n\nconst PodcastsProvider = ({ children }) => {\n  const [state, setState] = useState({ ...PodcastsInitialState });\n\n  const dispatchFactory = useCallback(async (type, payload) => {\n    try {\n      setState(\n        (prevState) => ({\n          ...prevState,\n          ui: { error: false, requesting: true },\n        }), // REQUESTING\n      );\n\n      const response = await dispatch({ type, payload });\n\n      if (response) {\n        setState((prevState) => ({\n          ...prevState,\n          ...response,\n          ui: { error: false, requesting: false }, // SUCCESS\n        }));\n      }\n    } catch (error) {\n      console.log(`PodcastsProvider - dispatchFactory() ${type} error`);\n      console.log(error);\n      setState((prevState) => ({\n        ...prevState,\n        ui: { error: true, requesting: false }, // ERROR\n      }));\n    }\n  }, []);\n\n  const actions = useMemo(\n    () => ({\n      getTopPodcasts: async () => {\n        await dispatchFactory(GET_TOP_PODCASTS);\n      },\n      getPodcastDetail: async (payload) => {\n        await dispatchFactory(GET_PODCAST_DETAIL, payload);\n      },\n      playPodcastItem: async (payload) => {\n        await dispatchFactory(PLAY_PODCAST_ITEM, payload);\n      },\n      resetPodcasts: async () => {\n        await dispatchFactory(RESET_PODCASTS);\n      },\n    }),\n    [],\n  );\n\n  return (\n    <PodcastsContext.Provider value={state}>\n      <PodcastsActionsContext.Provider value={actions}>\n        {children}\n      </PodcastsActionsContext.Provider>\n    </PodcastsContext.Provider>\n  );\n};\n\nexport default PodcastsProvider;\n","C:\\dev\\podjs\\src\\hooks\\usePodcastsContext.js",[],"C:\\dev\\podjs\\src\\screens\\PodcastDetail\\PodcastDetail.js",[],"C:\\dev\\podjs\\src\\utils\\parseRSS.js",[],["99","100","101","102","103"],"C:\\dev\\podjs\\src\\components\\Player\\Player.js",["104"],"/* eslint-disable react/prop-types */\nimport React from 'react';\nimport AudioPlayer from 'react-h5-audio-player';\nimport 'react-h5-audio-player/lib/styles.css';\nimport usePodcastsContext from '../../hooks/usePodcastsContext';\nimport './styles.scss';\n\nconst PodcastCard = () => {\n  const [{ player }] = usePodcastsContext();\n\n  return (\n    <div className=\"player-wrapper\">\n      <AudioPlayer\n        autoPlay\n        src={player.playing}\n        onPlay={() => console.log('onPlay')}\n        preload=\"metadata\"\n      />\n    </div>\n  );\n};\n\nexport default PodcastCard;\n",{"ruleId":"105","replacedBy":"106"},{"ruleId":"107","replacedBy":"108"},{"ruleId":"109","replacedBy":"110"},{"ruleId":"111","replacedBy":"112"},{"ruleId":"113","replacedBy":"114"},{"ruleId":"105","replacedBy":"115"},{"ruleId":"107","replace