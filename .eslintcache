nt":0,"fixableErrorCount":0,"fixableWarningCount":0},"C:\\dev\\podjs\\src\\index.js",[],["71","72","73","74","75"],"C:\\dev\\podjs\\src\\App.js",[],["76","77","78","79","80"],"C:\\dev\\podjs\\src\\reportWebVitals.js",[],["81","82","83","84","85"],"C:\\dev\\podjs\\src\\components\\DarkThemeProvider\\DarkThemeProvider.js",[],"C:\\dev\\podjs\\src\\components\\Navigator\\Navigator.js",[],"C:\\dev\\podjs\\src\\screens\\Dashboard\\Dashboard.js",[],"C:\\dev\\podjs\\src\\components\\PodcastCard\\PodcastCard.js",[],"C:\\dev\\podjs\\src\\hooks\\useContextFactory.js",[],"C:\\dev\\podjs\\src\\contexts\\Podcasts\\actions.js",["86","87","88","89","90","91","92","93","94","95"],"C:\\dev\\podjs\\src\\contexts\\Podcasts\\types.js",[],"C:\\dev\\podjs\\src\\contexts\\Podcasts\\context.js",[],"C:\\dev\\podjs\\src\\contexts\\Podcasts\\provider.js",["96","97"],"/* eslint-disable react/prop-types */\nimport React, { useCallback, useMemo, useState } from 'react';\nimport {\n  PodcastsContext,\n  PodcastsActionsContext,\n  PodcastsInitialState,\n} from './context';\nimport {\n  GET_TOP_PODCASTS,\n  GET_PODCAST_DETAIL,\n  RESET_PODCASTS,\n  PLAY_PODCAST_ITEM,\n} from './types';\nimport dispatch from './actions';\n\nconst PodcastsProvider = ({ children }) => {\n  const [state, setState] = useState({ ...PodcastsInitialState });\n\n  const dispatchFactory = useCallback(async (type, payload) => {\n    try {\n      setState(\n        (prevState) => ({\n          ...prevState,\n          ui: { error: false, requesting: true },\n        }), // REQUESTING\n      );\n\n      const response = await dispatch({ type, payload });\n\n      if (response) {\n        setState((prevState) => ({\n          ...prevState,\n          ...response,\n          ui: { error: false, requesting: false }, // SUCCESS\n        }));\n      }\n    } catch (error) {\n      console.log(`PodcastsProvider - dispatchFactory() ${type} error`);\n      console.log(error);\n      setState((prevState) => ({\n        ...prevState,\n        ui: { error: true, requesting: false }, // ERROR\n      }));\n    }\n  }, []);\n\n  const actions = useMemo(\n    () => ({\n      getTopPodcasts: async () => {\n        await dispatchFactory(GET_TOP_PODCASTS);\n      },\n      getPodcastDetail: async (payload) => {\n        await dispatchFactory(GET_PODCAST_DETAIL, payload);\n      },\n      playPodcastItem: async (payload) => {\n        await dispatchFactory(PLAY_PODCAST_ITEM, payload);\n      },\n      resetPodcasts: async () => {\n        await dispatchFactory(RESET_PODCASTS);\n      },\n    }),\n    [],\n  );\n\n  return (\n    <PodcastsContext.Provider value={state}>\n      <PodcastsActionsContext.Provider value={actions}>\n        {children}\n      </PodcastsActionsContext.Provider>\n    </PodcastsContext.Provider>\n  );\n};\n\nexport default PodcastsProvider;\n","C:\\dev\\podjs\\src\\hooks\\usePodcastsContext.js",[],"C:\\dev\\podjs\\src\\screens\\PodcastDetail\\PodcastDetail.js",[],"C:\\dev\\podjs\\src\\utils\\parseRSS.js",[],["98","99","100","101","102"],"C:\\dev\\podjs\\src\\components\\Player\\Player.js",[],{"ruleId":"103","replacedBy":"104"},{"ruleId":"105","replacedBy":"106"},{"ruleId":"107","replacedBy":"108"},{"ruleId":"109","replacedBy":"110"},{"ruleId":"111","replacedBy":"112"},{"ruleId":"103","replacedBy":"113"},{"ruleId":"105","replacedBy":"114"},{"ruleId":"107","replacedBy":"115"},{"ruleId":"109","replacedBy":"116"},{"ruleId":"111","replacedBy":"117"},{"ruleId":"103","replacedBy":"118"},{"ruleId":"105","replacedBy":"119"},{"ruleId":"107","replacedBy":"120"},{"ruleId":"109","replacedBy":"121"},{"ruleId":"111","replacedBy":"122"},{"ruleId":"123","severity":1,"message":"124","line":40,"column":5,"nodeType":"125","messageId":"126","endLine":40,"endColumn":16},{"ruleId":"123","severity":1,"message":"124","line":41,"column":5,"nodeType":"125","messageId":"126","endLine":41,"endColumn":16},{"ruleId":"123","severity":1,"message":"124","line":74,"column":5,"nodeType":"125","messageId":"126","endLine":