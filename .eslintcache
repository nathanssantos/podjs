ngCount":0,"usedDeprecatedRules":"70"},{"filePath":"71","messages":"72","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"73","messages":"74","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"75"},{"filePath":"76","messages":"77","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"46"},{"filePath":"78","messages":"79","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"46"},{"filePath":"80","messages":"81","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"57"},"C:\\dev\\podjs\\src\\index.js",[],["82","83","84","85","86"],"C:\\dev\\podjs\\src\\App.js",[],["87","88","89","90","91"],"C:\\dev\\podjs\\src\\reportWebVitals.js",[],["92","93","94","95","96"],"C:\\dev\\podjs\\src\\components\\DarkThemeProvider\\DarkThemeProvider.js",[],"C:\\dev\\podjs\\src\\components\\Navigator\\Navigator.js",[],"C:\\dev\\podjs\\src\\screens\\Dashboard\\Dashboard.js",[],"C:\\dev\\podjs\\src\\components\\PodcastCard\\PodcastCard.js",[],"C:\\dev\\podjs\\src\\hooks\\useContextFactory.js",[],["97","98","99","100","101"],"C:\\dev\\podjs\\src\\contexts\\Podcasts\\actions.js",[],["102","103","104","105","106"],"C:\\dev\\podjs\\src\\contexts\\Podcasts\\types.js",[],"C:\\dev\\podjs\\src\\contexts\\Podcasts\\context.js",[],"C:\\dev\\podjs\\src\\contexts\\Podcasts\\provider.js",["107","108"],"/* eslint-disable react/prop-types */\nimport React, { useCallback, useMemo, useState } from 'react';\nimport {\n  PodcastsContext,\n  PodcastsActionsContext,\n  PodcastsInitialState,\n} from './context';\nimport {\n  GET_TOP_PODCASTS,\n  GET_PODCAST_DETAIL,\n  RESET_PODCASTS,\n  PLAY_PODCAST_ITEM,\n  GET_FAVORITES,\n  REMOVE_FAVORITE,\n  ADD_FAVORITE,\n} from './types';\nimport dispatch from './actions';\n\nconst PodcastsProvider = ({ children }) => {\n  const [state, setState] = useState({ ...PodcastsInitialState });\n\n  const dispatchFactory = useCallback(async (type, payload) => {\n    try {\n      setState(\n        (prevState) => ({\n          ...prevState,\n          ui: { error: false, requesting: true },\n        }), // REQUESTING\n      );\n\n      const response = await dispatch({ type, payload });\n\n      if (response) {\n        setState((prevState) => ({\n          ...prevState,\n          ...response,\n          ui: { error: false, requesting: false }, // SUCCESS\n        }));\n      }\n    } catch (error) {\n      console.log(`PodcastsProvider - dispatchFactory() ${type} error`);\n      console.log(error);\n      setState((prevState) => ({\n        ...prevState,\n        ui: { error: true, requesting: false }, // ERROR\n      }));\n    }\n  }, []);\n\n  const actions = useMemo(\n    () => ({\n      getTopPodcasts: async () => {\n        await dispatchFactory(GET_TOP_PODCASTS);\n      },\n      getPodcastDetail: async (payload) => {\n        await dispatchFactory(GET_PODCAST_DETAIL, payload);\n      },\n      playPodcastItem: async (payload) => {\n        await dispatchFactory(PLAY_PODCAST_ITEM, payload);\n      },\n      getFavorites: async () => {\n        await dispatchFactory(GET_FAVORITES);\n      },\n      addFavorite: async (payload) => {\n        await dispatchFactory(ADD_FAVORITE, payload);\n      },\n      removeFavorite: async (payload) => {\n        await dispatchFactory(REMOVE_FAVORITE, payload);\n      },\n      resetPodcasts: async () => {\n        await dispatchFactory(RESET_PODCASTS);\n      },\n    }),\n    [],\n  );\n\n  return (\n    <PodcastsContext.Provider value={state}>\n      <PodcastsActionsContext.Provider value={actions}>\n        {children}\n      </PodcastsActionsContext.Provider>\n    </PodcastsContext.Provider>\n  );\n};\n\nexport default PodcastsProvider;\n","C:\\dev\\podjs\\src\\hooks\\usePodcastsContext.js",[],["109","110","111","112","113"],"C:\\dev\\podjs\\src\\screens\\PodcastDetail\\PodcastDetail.js",[],"C:\\dev\\podjs\\src\\utils\\parseRSS.js",[],["114","115","116","117","118"],"C:\\dev\\podjs\\src\\components\\Player\\Player.js",[],"C:\\dev\\podjs\\src\\hooks\\useLocalStorage.js",[],"C:\\dev\\podjs\\src\\screens\\Favorites\\Favorites.js",[],{"ruleId":"119","replacedBy":"120"},{"ruleId":"121","replacedBy":"122"},{"ruleId":"123","replacedBy":"124"},{"ruleId":"125","replacedBy":"126"},{"ruleId":"127","replacedBy":"128"},{"ruleId":"119","replacedBy":"129"},{"ruleId":"121","replacedBy":"130"},{"ruleId":"123","replacedBy":"131"},{"ruleId":"125","replacedBy":"132"},{"ruleId":"127","replacedBy":"133"},{"ruleId":"119","replacedBy":"134"},{"ruleId":"121","replacedBy":"135"},{"ruleId":"123","replacedBy":"136"},{"ruleId":"125","replacedBy":"137"},{"ruleId":"127","replacedBy":"138"},{"ruleId":"119","replacedBy":"139"},{"ruleId":"121","replacedBy":"140"},{"ruleId":"123","replacedBy":"141"},{"ruleId":"125","replacedBy":"142"},{"ruleId":"127","replacedBy":"143"},{"ruleId":"119","replacedBy":"144"},{"ruleId":"121","replacedBy":"145"},{"ruleId":"123","replacedBy":"146"},{"ruleId":"125","replacedBy":"147"},{"ruleId":"127","replacedBy":"148"},{"ruleId":"149","severity":1,"message":"150","line":41,"column":7,"nodeType":"151","messageId":"152","endLine":41,"endColumn":18},{"ruleId":"149","severity":1,"message":"150","line":42,"column":7,"nodeType":"151","messageId":"152","endLine":42,"endColumn":18},{"ruleId":"119","replacedBy":"153"},{"ruleId":"121","replacedBy":"154"},{"ruleId":"123","replacedBy":"155"},{"ruleId":"125","replacedBy":"156"},{"ruleId":"127","replacedBy":"157"},{"ruleId":"119","replacedBy":"158"},{"ruleId":"121","replacedBy":"159"},{"ruleId":"123","replacedBy":"160"},{"ruleId":"125","replacedBy":"161"},{"ruleId":"127","replacedBy":"162"},"lines-around-directive",["163"],"global-require",[],"no-buffer-constructor",[],"no-new-require",[],"no-path-concat",[],["163"],[],[],[],[],["163"],[],[],[],[],["163"],[],[],[],[],["163"],[],[],[],[],"no-console",